font_size = 64

[node name="NoclipMessage2" type="Label3D" parent="Texts" unique_id=1228957047]
transform = Transform3D(-0.9992033, 0, -0.039905056, 0, 1, 0, 0.039905056, 0, -0.9992033, 21.857693, 2.687654, 15.874239)
text = "The Concept Gallery.
Right now All of the images are either 
AI generated or first generated and then 
redrawn from hand 
as part of my 55th attempt to learn how to draw.
***
I'm aware of your attitude toward AI and I agree. 
Clankers won't replace us!"
font_size = 64

[node name="Label3D" type="Label3D" parent="Texts" unique_id=2120074948]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 32.811676, 2.9307303, 5.1491756)
text = "Button test to ensure that 
it's not frustrating when 
several objects are located 
close to each other."

