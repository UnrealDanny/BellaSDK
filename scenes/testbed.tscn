[node name="Label3D4" type="Label3D" parent="Texts" unique_id=203954150]
transform = Transform3D(-4.371139e-08, 0, -1, 0, 1, 0, 1, 0, -4.371139e-08, -10.423342, 1.8570591, -6.009865)
text = "This gate has an incredible 
amount of glitches. 
Programming is harder 
than I anticipated.
*
No pain - no gain
 and unfortunately for pain - I like pain. Let's see who 
