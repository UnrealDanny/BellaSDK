[sub_resource type="GDScript" id="GDScript_4mrxx"]
script/source = "extends StaticBody3D

@onready var prompt_label: Label3D = $Label3D

func interact():
	print(\"picked up the item!\")
	queue_free()
	
func show_prompt():
	prompt_label.visible = true
	
func hide_prompt():
	prompt_label.visible = false
"

