transform = Transform3D(-4.371139e-08, 0, 1, 0, 1, 0, -1, 0, -4.371139e-08, -19.094444, 2.28909, 23.42018)
text = "WELCOME! Welcome to BellaSDK hub! 
You have chosen or been chosen to try this 
AI generated slop.

The goal is to democratize game development 
and help noobs quickly learn the basics of GD and LD.
***
True HL3 can only be made by US 
- 
THE PEOPLE!"
font_size = 64

